<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:Sample.Pages"
       x:Class="Sample.AppShell"
       Title="Shiny Diagrams Sample">

    <TabBar>
        <ShellContent
            Title="Flowchart"
            ContentTemplate="{DataTemplate pages:BasicFlowchartPage}"
            Route="BasicFlowchartPage" />

        <ShellContent
            Title="Editor"
            ContentTemplate="{DataTemplate pages:InteractiveEditorPage}"
            Route="InteractiveEditorPage" />

        <ShellContent
            Title="Themes"
            ContentTemplate="{DataTemplate pages:ThemesPage}"
            Route="ThemesPage" />

        <ShellContent
            Title="Directions"
            ContentTemplate="{DataTemplate pages:DirectionsPage}"
            Route="DirectionsPage" />

        <ShellContent
            Title="Subgraphs"
            ContentTemplate="{DataTemplate pages:SubgraphsPage}"
            Route="SubgraphsPage" />
    </TabBar>

</Shell>
